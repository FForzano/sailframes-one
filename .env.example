# SailFrames environment variables.
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit
# real secrets. These drive docker-compose.yml (the self-hosted stack).

# --- MinIO (S3-compatible blob storage) ---
# Root credentials; also handed to the API + workers as AWS_* creds.
MINIO_ROOT_USER=sailframes
MINIO_ROOT_PASSWORD=change-me-long-secret

# --- Object storage ---
SAILFRAMES_BUCKET=sailframes-fleet-data-prod
SAILFRAMES_DATA_PREFIX=processed
AWS_DEFAULT_REGION=us-east-1

# Shared secret gating the MinIO -> /hooks/minio ingest webhook.
SAILFRAMES_HOOK_TOKEN=change-me-random-token

# --- Postgres (metadata) ---
# The compose file wires POSTGRES_HOST/PORT to the `postgres` service; only the
# credentials below are read from .env. backend/db builds the SQLAlchemy URL
# from these discrete vars (no password embedded in a single DATABASE_URL token).
POSTGRES_USER=sailframes
POSTGRES_PASSWORD=change-me-long-secret
POSTGRES_DB=sailframes

# --- Auth ---
# Secret for signing HS256 access JWTs (required for native login).
SAILFRAMES_JWT_SECRET=change-me-random-jwt-secret
# Optional first superadmin, seeded on startup.
SAILFRAMES_SUPERADMIN_EMAIL=
SAILFRAMES_SUPERADMIN_PASSWORD=

# --- Production only (deploy/docker-compose.prod.yml) ---
# Set to "1" once served over HTTPS (via the Cloudflare Tunnel below) so
# auth cookies get the Secure flag; leave "0"/unset for local dev over http.
SAILFRAMES_COOKIE_SECURE=0
# Browser-reachable MinIO address for presigned upload/download URLs —
# the second Cloudflare Tunnel public hostname below, e.g.
# https://minio.xgsail.com. See the comment on this var in
# docker-compose.yml for what happens if it's left unset.
SAILFRAMES_S3_PUBLIC_ENDPOINT=https://minio.xgsail.com
# Token for the Cloudflare Tunnel. Created in the Cloudflare Zero Trust
# dashboard (Networks > Tunnels); not needed for local dev. One tunnel
# routes both public hostnames (configured in the dashboard, not here):
#   xgsail.com       -> http://frontend:80
#   minio.xgsail.com -> http://minio:9000
CLOUDFLARE_TUNNEL_TOKEN=
