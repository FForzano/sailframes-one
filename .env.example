# SailFrames environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.
#
# In production (AWS Lambda) these go on the function as Environment Variables
# (Lambda Console → Configuration → Environment variables) or in AWS Secrets
# Manager. The same env var names are read by the Lambda at runtime.

# --- Synoptic Data (Mesonet aggregator) ---
# Generate a TOKEN (not the API Key) from your Customer Console:
#   https://customer.synopticdata.com/  →  Credentials → Tokens → Create Token
# The TOKEN is what you put here. The API Key stays in the Synoptic console;
# never store the API Key on disk or in code.
SYNOPTIC_TOKEN=

# --- WeatherFlow / Tempest (optional, separate provider) ---
# Generate via the Tempest mobile app once an account is set up:
#   Settings → Data Authorizations → Personal Use Token
WEATHERFLOW_TOKEN=

# --- AWS profile (used by deploy.sh + flash-e1.sh helpers) ---
# Profile name in ~/.aws/credentials, not the access key itself.
AWS_PROFILE=sailframes
