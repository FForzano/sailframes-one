# Release signing config for the Android build — read by app/build.gradle.
# Copy to keystore.properties (gitignored, never commit the real one) and
# fill in real values, or let .github/workflows/android-release.yml
# generate this file in CI from repo secrets (ANDROID_KEYSTORE_BASE64,
# ANDROID_KEYSTORE_PASSWORD, ANDROID_KEY_ALIAS, ANDROID_KEY_PASSWORD).
#
# Generate the keystore itself with (run once, then store it safely — a
# lost keystore means you can never publish an update under the same
# signature/app identity again):
#   keytool -genkeypair -v -keystore release.keystore -alias xgsail \
#     -keyalg RSA -keysize 2048 -validity 10000

storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=xgsail
keyPassword=CHANGE_ME
