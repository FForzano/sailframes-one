# ota-service environment variables.
#
# In docker-compose.yml these are wired automatically from the repo-root
# .env (same MinIO instance/credentials as backend/frontend) — this file is
# only for running ota-service standalone (npm run dev) outside compose.

# --- MinIO (same instance/bucket/creds as the rest of the stack) ---
MINIO_ROOT_USER=sailframes
MINIO_ROOT_PASSWORD=change-me-long-secret
SAILFRAMES_S3_ENDPOINT=http://localhost:9000
SAILFRAMES_BUCKET=sailframes-fleet-data-prod

# --- OTA-specific (new) ---
# Key prefix within the shared bucket: {prefix}/manifest.json,
# {prefix}/bundles/{version}.zip.
SAILFRAMES_OTA_PREFIX=app-updates
OTA_PORT=8081
