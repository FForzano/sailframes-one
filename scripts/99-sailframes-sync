#!/bin/bash
#
# NetworkManager dispatcher script
# Triggers SailFrames sync when WiFi connects
#
# Install to: /etc/NetworkManager/dispatcher.d/99-sailframes-sync
# Make executable: chmod +x /etc/NetworkManager/dispatcher.d/99-sailframes-sync
#

INTERFACE="$1"
ACTION="$2"

# Only trigger on WiFi up events
if [[ "$ACTION" == "up" ]] && [[ "$INTERFACE" == "wlan0" ]]; then
    # Log the trigger
    logger -t sailframes-sync "WiFi connected on $INTERFACE, triggering sync"

    # Wait for network to stabilize
    sleep 10

    # Trigger sync (non-blocking)
    systemctl start sailframes-sync.service &
fi
